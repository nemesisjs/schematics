{
  "name": "@nemesis-js/schematics",
  "version": "1.0.0",
  "type": "module",
  "description": "NemesisJS code generation schematics — engine + all built-in schematics",
  "author": "NemesisJS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nemesisjs/schematics.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "collection.json"
  ],
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./collection.json": "./collection.json"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "test": "bun test"
  },
  "dependencies": {
    "ejs": "^3.1.10"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ejs": "^3.1.5",
    "typescript": "^5.7.0"
  }
}
